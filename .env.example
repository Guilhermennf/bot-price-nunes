# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
TELEGRAM_CHAT_ID=@yourchannel
# Your PRIVATE chat id — operational alerts (channel silent, etc). Optional.
ADMIN_CHAT_ID=
ALERT_QUIET_HOURS=8

# Supabase (use the service_role key for server-side writes)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# Gemini (Google AI Studio)
GEMINI_API_KEY=your-gemini-api-key

# Curation: tech-only channel + store whitelist (canonical ids, see app/stores.py)
TECH_ONLY=true
ALLOWED_STORES=amazon,mercadolivre,aliexpress,shopee,magalu

# Affiliate (leave empty = links untouched; fill when the accounts exist)
AMAZON_ASSOC_TAG=
ML_AFFILIATE_TOOL_ID=

# Feature flags / tuning
ENABLE_CHECKOUT_SIM=false
# Direct price-confirm via headless browser. Leave false: ML/Amazon wall
# datacenter IPs (GitHub Actions), so it rarely helps and is slow.
ENABLE_BROWSER_CONFIRM=false
MIN_SCORE=70
MIN_DISCOUNT_PCT=10
HISTORY_WINDOW_DAYS=90
REPOST_COOLDOWN_DAYS=7
MAX_DEALS_PER_RUN=15
